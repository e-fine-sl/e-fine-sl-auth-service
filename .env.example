# e-Fine SL Auth Microservice - Environment Variables
# Copy to .env and fill real values. NEVER commit .env to git!

PORT=4000
NODE_ENV=development

# Same MongoDB Atlas cluster as main backend
MONGO_URI=

# JWT Secrets - generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# RSA Private Key - paste ENTIRE private.pem content here, newlines as \n
# Generate keypair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
RSA_PRIVATE_KEY=

# Shared internal secret - same value in main backend .env
# Only lets main backend call /auth/verify  
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=
